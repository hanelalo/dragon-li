{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default-permissions",
  "description": "Default permissions for the application",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    "shell:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "runtime_agent",
          "cmd": "runtime_agent",
          "args": true,
          "sidecar": true
        }
      ]
    }
  ]
}
